{
  "name": "server",
  "version": "0.1.0",
  "description": "API service for the application",
  "type": "module",
  "imports": {
    "#features/*": {
      "types": "./src/features/*.ts",
      "default": "./dist/features/*.js"
    },
    "#lib/*": {
      "types": "./src/lib/*.ts",
      "default": "./dist/lib/*.js"
    },
    "#middleware/*": {
      "types": "./src/middleware/*.ts",
      "default": "./dist/middleware/*.js"
    },
    "#routes/*": {
      "types": "./src/app/routes/*.ts",
      "default": "./dist/app/routes/*.js"
    },
    "#services/*": {
      "types": "./src/services/*.ts",
      "default": "./dist/services/*.js"
    },
    "#utils/*": {
      "types": "./src/utils/*.ts",
      "default": "./dist/utils/*.js"
    }
  },
  "engines": {
    "node": ">=20.11.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "start": "npm run build && node --env-file=.env.dev dist/server.js",
    "debug": "npm run build && node --env-file=.env.dev --inspect dist/server.js",
    "build": "tsc",
    "build:clean": "rm -rf dist && tsc",
    "dev": "tsx watch src/server.ts",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,md}\"",
    "precommit": "pretty-quick --staged",
    "lint": "eslint .",
    "lint:fix": "eslint \"src\" --ext .ts,.js --fix",
    "lint:root": "eslint \"*.{ts,mjs,json,mts}\"",
    "lint:config:fix": "eslint \"*.{ts,mjs,json,mts}\" --fix",
    "lint:format": "pretty-quick --staged",
    "prepare": "husky",
    "prepare-commit-msg": "node tools/git-commit-message.js .git/COMMIT_EDITMSG",
    "start:prod": "node --env-file=.env.production dist/server.js"
  },
  "dependencies": {
    "@google/genai": "^1.50.1",
    "@site8/shared": "file:../shared",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.0",
    "valibot": "^1.3.1",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "@types/validator": "^13.15.10",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-check-file": "^3.3.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-n": "^18.0.1",
    "eslint-plugin-no-secrets": "^2.3.3",
    "eslint-plugin-perfectionist": "^5.9.0",
    "eslint-plugin-prefer-arrow-functions": "^3.9.1",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-regexp": "^3.1.0",
    "eslint-plugin-security": "^4.0.0",
    "eslint-plugin-sonarjs": "^4.0.3",
    "eslint-plugin-unicorn": "^64.0.0",
    "eslint-plugin-vitest": "^0.5.4",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "prettier": "^3.8.3",
    "pretty-quick": "^4.2.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0",
    "tsx": "^4.19.2"
  },
  "keywords": [
    "api",
    "express",
    "typescript",
    "nodejs"
  ],
  "author": "John Doe <john.doe@example.com>",
  "license": "UNLICENSED",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/username/repository.git"
  },
  "bugs": {
    "url": "https://github.com/username/repository/issues"
  },
  "homepage": "https://github.com/username/repository#readme"
}
